# ============================================================
# BetClaude — Production Environment Variables
# Copy to .env and fill in your values
# ============================================================

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=betclaude
DB_USER=betclaude
DB_PASSWORD=change-me-db-password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=change-me-access-secret-64-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-64-chars

# API Gateway
API_HOST=0.0.0.0
API_PORT=3000
NODE_ENV=production

# Claude CLI
CLAUDE_CLI_PATH=claude
CLAUDE_MAX_TOKENS=200000

# Sports Data APIs (optional — system works with mock data without them)
API_FOOTBALL_KEY=
SPORTRADAR_KEY=
PINNACLE_API_KEY=
NEWSAPI_KEY=
OPENWEATHER_API_KEY=

# Python Analytics Service
ANALYTICS_HOST=0.0.0.0
ANALYTICS_PORT=8000
ANALYTICS_SERVICE_URL=http://analytics:8000

# Frontend
VITE_API_URL=http://localhost:3000
